POSTGRES_PASSWORD=change-this-postgres-password
AMOR_API_KEY=change-this-api-key
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Optional: defaults to allowing Chrome extension origins.
# CORS_ALLOWED_ORIGIN_REGEX=^chrome-extension://.*$

# Optional JWT auth support.
# AMOR_JWT_SECRET=change-this-jwt-secret
# AMOR_JWT_ALGORITHM=HS256

# Optional upload/runtime tuning.
# MAX_UPLOAD_FILES=5
# MAX_UPLOAD_BYTES_PER_FILE=10485760
# ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp

# Optional detection tuning.
# PHASH_MATCH_THRESHOLD=10
# REGION_PHASH_MATCH_THRESHOLD=12
# FACE_MATCH_DISTANCE_THRESHOLD=0.55
